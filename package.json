{
  "name": "@naclac-fw/client",
  "version": "0.1.0",
  "description": "The official TypeScript SDK for the Naclac framework",
  "license": "Apache-2.0",
  "author": "Naclac Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/naclacframework/naclac-client"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "ts-mocha -p ./tsconfig.json -t 60000 \"tests/**/*.ts\""
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@solana/codecs": "^6.5.0",
    "@solana/kit": "^6.5.0",
    "gill": "^0.14.0"
  },
  "devDependencies": {
    "@types/mocha": "^9.0.0",
    "@types/node": "^22.0.0",
    "mocha": "^9.0.3",
    "ts-mocha": "^11.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.3"
  }
}
